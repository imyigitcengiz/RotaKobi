# Coolify → Environment Variables (İSTEĞE BAĞLI)
#
# Tak-çalıştır: Environment sekmesine HİÇBİR ŞEY yazmadan deploy edin.
# Tüm değerler docker-compose.yml + bootstrap-env.sh ile gelir.
#
# Tam referans: repo kökündeki .env.example
# Sadece override istiyorsanız aşağıdaki satırları Environment'a yapıştırın.

# --- Otomatik (yazmayın) ---
# DJANGO_SECRET_KEY=
# DJANGO_ALLOWED_HOSTS=
# DJANGO_CSRF_TRUSTED_ORIGINS=
# DJANGO_SECURE_SSL=

# --- İlk kurulum ---
DJANGO_ENSURE_SUPERADMIN=1

# --- Override gerekmez (compose'ta hazır) ---
# WHATSAPP_BRIDGE_URL=http://whatsapp_bridge:3939
# DJANGO_WHATSAPP_BRIDGE_CAN_SPAWN=0
# DJANGO_WHATSAPP_BRIDGE_WAIT_ON_START=1
# MEDIA_COMPRESS_ENABLED=1
