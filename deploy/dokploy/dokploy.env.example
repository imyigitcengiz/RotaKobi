# =============================================================================
# CoolOPS — Dokploy Environment şablonu
# Repo: https://github.com/imyigitcengiz/RotaKobi
# =============================================================================
#
# Dokploy → Project → Docker Compose → Environment
#
# Kurulum:
#   1. Source: GitHub → imyigitcengiz/RotaKobi, branch main
#   2. Compose path: docker-compose.yaml
#   3. Environment: bu dosyadaki minimal satırlar
#   4. Domains → servis "app", container port 80
#   5. Deploy
#
# Otomatik (bootstrap-env.sh + panel-domain.sh):
#   DATABASE_URL, REDIS_URL, DJANGO_SECRET_KEY
#   DJANGO_ALLOWED_HOSTS, DJANGO_CSRF_TRUSTED_ORIGINS
#   SERVICE_FQDN_APP, SERVICE_URL_APP (Domains sekmesinden)
# =============================================================================

COMPOSE_FILE=docker-compose.yaml:deploy/dokploy/docker-compose.dokploy.yaml

DJANGO_ENSURE_SUPERADMIN=1
DJANGO_DEBUG=0

# İlk girişten sonra kapatın:
# DJANGO_ENSURE_SUPERADMIN=0

# Şifre sıfırlama (tek redeploy):
# DJANGO_ENSURE_SUPERADMIN_RESET=1

# Özel DB şifresi (isteğe bağlı — varsayılan coolops):
# POSTGRES_PASSWORD=guclu-sifre
# POSTGRES_USER=coolops
# POSTGRES_DB=coolops

# GitHub panel güncellemesi (isteğe bağlı):
# COOLOPS_UPDATE_REPO=imyigitcengiz/RotaKobi
# COOLOPS_PANEL_GIT_UPDATE=1
