# Dokploy → Docker Compose → Environment sekmesine yapıştırın
# veya bu dosyayı compose ile aynı dizinde .env olarak kaydedin.
#
# Zorunlu: DJANGO_SECRET_KEY, DJANGO_ALLOWED_HOSTS, DJANGO_CSRF_TRUSTED_ORIGINS

DJANGO_SECRET_KEY=uzun-rastgele-gizli-anahtar
DJANGO_ALLOWED_HOSTS=panel.ornek.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://panel.ornek.com
DJANGO_SECURE_SSL=1
DJANGO_DEBUG=0

# İlk kurulum (admin / admin) — girişten sonra 0 yapın ve yeniden deploy edin
DJANGO_ENSURE_SUPERADMIN=1

# Compose içindeki servis adı (değiştirmeyin)
WHATSAPP_BRIDGE_URL=http://whatsapp-bridge:3939
DJANGO_WHATSAPP_BRIDGE_CAN_SPAWN=0
DJANGO_WHATSAPP_BRIDGE_AUTO_START=0

# Kalıcı veri — named volume gy_data → /data (compose.yaml)
# GY_ALLOW_EPHEMERAL_DATA=1  # yalnızca test; üretimde kullanmayın

MEDIA_COMPRESS_ENABLED=1
