# Dokploy → Environment sekmesi (İSTEĞE BAĞLI)
#
# Tak-çalıştır: Environment boş bırakılabilir.
# docker-compose.yml + bootstrap-env.sh otomatik yapılandırır.
#
# Tam referans: repo kökündeki .env.example

# --- Otomatik (yazmayın) ---
# DJANGO_SECRET_KEY=
# DJANGO_ALLOWED_HOSTS=
# DJANGO_CSRF_TRUSTED_ORIGINS=
# DJANGO_SECURE_SSL=

# --- İlk kurulum ---
DJANGO_ENSURE_SUPERADMIN=1
DJANGO_DEBUG=0

# --- Override gerekmez (compose'ta hazır) ---
# WHATSAPP_BRIDGE_URL=http://whatsapp_bridge:3939
# DJANGO_WHATSAPP_BRIDGE_CAN_SPAWN=0
# DJANGO_WHATSAPP_BRIDGE_WAIT_ON_START=1
# MEDIA_COMPRESS_ENABLED=1
