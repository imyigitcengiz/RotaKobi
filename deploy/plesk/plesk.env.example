# =============================================================================
# CoolOPS — Plesk Git deploy ortamı
# Domain: deploy.sh vhost yolundan otomatik VEYA KOBIOPS_DOMAIN
# Ortak şablon: deploy/panel.env.template · deploy/DOMAIN.md
# =============================================================================
#
# Sunucuda bir kez:
#   cp deploy/plesk/plesk.env.example deploy/plesk/plesk.env
# deploy/plesk/plesk.env git'e girmez.
#
# Git deploy action: /bin/bash deploy/plesk/deploy.sh
# =============================================================================

# Plesk subdomain (boş bırakılırsa vhost yolundan algılanır)
# KOBIOPS_DOMAIN=ops.ornek.com

# nginx reverse proxy → 127.0.0.1:8000 (deploy/plesk/nginx-proxy.conf)
KOBIOPS_HTTP_PORT=8000

DJANGO_ENSURE_SUPERADMIN=1

# KOBIOPS_PUBLIC_URL otomatik https:// (sslip.io ise http://)
